# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Build artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Notebook artifacts
.ipynb_checkpoints/

# Test and coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Type-check/cache artifacts
.mypy_cache/
.ruff_cache/

# IDE/editor artifacts
.vscode/
.idea/

# OS artifacts
.DS_Store
Thumbs.db

# Project-specific exclusions
logs/
weights/
*.safetensors
*.pt
*.npz
*.csv
!experiments/genesis/prompts/*.csv

# SGT runner intermediate dirs (HF Trainer scratch)
experiments/sgt/runs/**/_tmp_*/
experiments/sgt/runs/**/checkpoint-*/
# But keep per-run JSONs and analysis outputs
!experiments/sgt/runs/**/*.json
!experiments/sgt/analysis/**/*.json
!experiments/sgt/analysis/**/*.png
